#include <stdio.h>

int main() {

    // long is needed because the number can be very large, so we use long long to store it
    long long num;

   
    int sum = 0;

    scanf("%lld", &num);

    // Check if the number is negative
    if (num < 0) {
        printf("Number is negative");
    } else {

        // Find the sum of all digits
        while (num > 0) {
            sum += num % 10;   // Get the last digit and add it to sum
            num = num / 10;    // Remove the last digit
        }

        // Print the final sum
        printf("%d", sum);
    }

    return 0;
}