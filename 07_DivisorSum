#include <stdio.h>

int main() {
    int n;
    int sum = 0;

    // Take input
    scanf("%d", &n);

    // Find the sum of all proper divisors
    for (int i = 1; i < n; i++) {
        if (n % i == 0) {
            sum = sum + i;
        }
    }

    // Print the result
    printf("%d", sum);

    return 0;
}