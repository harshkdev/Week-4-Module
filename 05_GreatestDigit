#include <stdio.h>

int main() {

    
    long long num;

    // Variable to store the largest digit
    int max = 0;

    scanf("%lld", &num);

    // Check if the number is negative
    if (num < 0) {
        printf("Negative number...");
    } else {

        // Find the largest digit
        while (num > 0) {

            int digit = num % 10;

            if (digit > max) {
                max = digit;
            }

            num = num / 10;
        }

        // Print the largest digit
        printf("%d", max);
    }

    return 0;
}