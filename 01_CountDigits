#include <stdio.h>

int main() {
    int num, count = 0;

    printf("Enter your digit: ");
    scanf("%d", &num);

    if (num < 0) {
        num = -num;   // Convert negative number to positive
    }

    if (num == 0) {
        count = 1;
    } else {
        while (num > 0) {
            num = num / 10;
            count++;
        }
    }

    printf("Number of digits = %d\n", count);

    return 0;
}